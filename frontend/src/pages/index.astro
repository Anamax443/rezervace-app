---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Rezervace App</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Segoe UI, sans-serif; background: #0D0B10; color: #E8E8F0; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 20px; }
    .header { text-align: center; margin-bottom: 48px; }
    .header .logo { font-size: 40px; margin-bottom: 12px; }
    .header h1 { font-family: Georgia, serif; font-size: 28px; color: #F5E6E8; margin-bottom: 6px; }
    .header p { font-size: 13px; color: #5A3A42; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; max-width: 900px; width: 100%; margin-bottom: 48px; }
    .card { background: #1A1015; border: 1px solid #2A1520; border-radius: 14px; padding: 24px; text-decoration: none; color: inherit; transition: border-color 0.2s, background 0.2s; display: flex; flex-direction: column; gap: 10px; }
    .card:hover { border-color: #C0395A; background: #1F1318; }
    .card .icon { font-size: 28px; }
    .card .label { font-size: 11px; color: #5A3A42; text-transform: uppercase; letter-spacing: 0.08em; }
    .card h2 { font-size: 17px; color: #F5E6E8; font-weight: 600; }
    .card p { font-size: 12px; color: #6B4A52; line-height: 1.6; }
    .card .arrow { font-size: 12px; color: #C0395A; margin-top: auto; padding-top: 8px; }
    .card.highlight { border-color: #3D1525; background: #1A0D12; }
    .card.highlight:hover { border-color: #C0395A; }
    .section-title { font-size: 11px; color: #3D2A32; text-transform: uppercase; letter-spacing: 0.1em; max-width: 900px; width: 100%; margin-bottom: 8px; margin-top: 8px; }
    .workers { display: flex; flex-wrap: wrap; gap: 10px; max-width: 900px; width: 100%; margin-bottom: 32px; }
    .worker { background: #110D14; border: 1px solid #1E1520; border-radius: 8px; padding: 10px 16px; font-size: 12px; color: #4A3A42; text-decoration: none; transition: color 0.2s, border-color 0.2s; }
    .worker:hover { color: #C0395A; border-color: #3D1525; }
    .worker span { color: #2A1A22; margin-right: 6px; }
  </style>
</head>
<body>
  <div class="header">
    <div class="logo">🍷</div>
    <h1>Rezervace App</h1>
    <p>Interní systémový rozcestuík</p>
  </div>

  <div class="section-title">Administrace</div>
  <div class="grid">
    <a href="/login" class="card highlight">
      <div class="icon">🔐</div>
      <div class="label">Přihlášení</div>
      <h2>Přihlásit se</h2>
      <p>Přihlášení do administrace systému</p>
      <div class="arrow">/login →</div>
    </a>
    <a href="/superadmin" class="card">
      <div class="icon">🛡</div>
      <div class="label">Superadmin</div>
      <h2>Superadmin konzole</h2>
      <p>Správa tenantů, uživatelů, systémový stav</p>
      <div class="arrow">/superadmin →</div>
    </a>
    <a href="/superadmin/system" class="card">
      <div class="icon">📊</div>
      <div class="label">Monitoring</div>
      <h2>Stav systému</h2>
      <p>Health check 8 služeb, API klíče, terminál</p>
      <div class="arrow">/superadmin/system →</div>
    </a>
    <a href="/admin" class="card">
      <div class="icon">🏢</div>
      <div class="label">Admin tenantu</div>
      <h2>Admin konzole</h2>
      <p>Správa akcí, rezervací a uživatelů tenantu</p>
      <div class="arrow">/admin →</div>
    </a>
  </div>

  <div class="section-title">Zákaznícký web</div>
  <div class="grid">
    <a href="/novak" class="card">
      <div class="icon">🍷</div>
      <div class="label">Demo tenant</div>
      <h2>Vinotéka Novák</h2>
      <p>Ukázkový tenant — seznam akcí, rezervace, platba</p>
      <div class="arrow">/novak →</div>
    </a>
  </div>

  <div class="section-title">Workers API</div>
  <div class="workers">
    <a href="https://admin-api.bass443.workers.dev/health" target="_blank" class="worker"><span>GET</span>admin-api /health</a>
    <a href="https://fio-polling.bass443.workers.dev/health" target="_blank" class="worker"><span>GET</span>fio-polling /health</a>
    <a href="https://fio-billing.bass443.workers.dev/health" target="_blank" class="worker"><span>GET</span>fio-billing /health</a>
    <a href="https://rezervace.bass443.workers.dev/health" target="_blank" class="worker"><span>GET</span>rezervace /health</a>
    <a href="https://image-optimizer.bass443.workers.dev/health" target="_blank" class="worker"><span>GET</span>image-optimizer /health</a>
  </div>
</body>
</html>
