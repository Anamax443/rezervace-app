---
---
<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>API klíče | Rezervace Admin</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #0f172a; color: #f1f5f9; }
    .sidebar { position: fixed; left: 0; top: 0; bottom: 0; width: 240px; background: #1e293b; border-right: 1px solid #334155; padding: 1.5rem 0; }
    .logo { padding: 0 1.5rem 1.5rem; border-bottom: 1px solid #334155; font-weight: 700; font-size: 1.1rem; }
    .logo span { color: #6366f1; }
    nav a { display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 1.5rem; color: #94a3b8; text-decoration: none; font-size: 0.9rem; }
    nav a:hover, nav a.active { color: #f1f5f9; background: #334155; }
    nav a.active { border-right: 2px solid #6366f1; }
    .main { margin-left: 240px; padding: 2rem; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
    .header h1 { font-size: 1.5rem; }
    .user-info { color: #94a3b8; font-size: 0.875rem; display: flex; align-items: center; gap: 1rem; }
    .badge { background: #6366f1; color: white; padding: 0.2rem 0.6rem; border-radius: 99px; font-size: 0.75rem; font-weight: 600; }
    .logout { color: #94a3b8; cursor: pointer; background: none; border: 1px solid #334155; padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.8rem; }
    .card { background: #1e293b; border: 1px solid #334155; border-radius: 10px; padding: 1.5rem; margin-bottom: 1rem; }
    .card-title { font-size: 1rem; font-weight: 600; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
    .key-row { display: flex; gap: 0.75rem; align-items: center; margin-bottom: 0.75rem; flex-wrap: wrap; }
    .key-input { flex: 1; min-width: 250px; background: #0f172a; border: 1px solid #334155; color: #f1f5f9; padding: 0.5rem 0.75rem; border-radius: 6px; font-family: 'Cascadia Code','Consolas',monospace; font-size: 0.85rem; }
    .key-input:focus { outline: none; border-color: #6366f1; }
    .btn { background: #6366f1; color: white; border: none; padding: 0.5rem 1rem; border-radius: 6px; cursor: pointer; font-size: 0.85rem; font-weight: 600; white-space: nowrap; }
    .btn:hover { background: #4f46e5; }
    .btn:disabled { background: #334155; cursor: not-allowed; }
    .btn-outline { background: transparent; border: 1px solid #334155; color: #94a3b8; }
    .btn-outline:hover { background: #334155; color: #f1f5f9; }
    .key-status { font-size: 0.8rem; padding: 0.2rem 0.5rem; border-radius: 4px; white-space: nowrap; }
    .key-status.ok { background: #14532d; color: #4ade80; }
    .key-status.error { background: #451a03; color: #f87171; }
    .key-status.pending { background: #1e293b; color: #64748b; }
    details { margin-top: 0.5rem; }
    details summary { color: #64748b; font-size: 0.8rem; cursor: pointer; user-select: none; }
    details summary:hover { color: #94a3b8; }
    details .help-text { color: #64748b; font-size: 0.8rem; padding: 0.5rem 0 0 1rem; line-height: 1.6; }
    details .help-text code { background: #0f172a; padding: 0.1rem 0.4rem; border-radius: 3px; font-size: 0.8rem; }
    .btn-test-all { margin-bottom: 1rem; }
  </style>
  <script src="/lang.js" is:inline></script>
</head>
<body>
  <aside class="sidebar">
    <div class="logo">Rezervace <span>Admin</span></div>
    <nav>
      <a href="/superadmin"><span data-i18n="dashboard">Dashboard</span></a>
      <a href="/superadmin/tenants"><span data-i18n="tenants">Tenanti</span></a>
      <a href="/superadmin/users"><span data-i18n="users">U\u017eivatele</span></a>
      <a href="/superadmin/event-log"><span data-i18n="eventLog">Event Log</span></a>
      <a href="/superadmin/system"><span data-i18n="systemCheck">Stav syst\u00e9mu</span></a>
      <a href="/superadmin/api-keys" class="active"><span data-i18n="apiKeys">API kl\u00ed\u010de</span></a>
    </nav>
  </aside>
  <main class="main">
    <div class="header">
      <h1 data-i18n="apiKeys">API kl\u00ed\u010de</h1>
      <div class="user-info">
        <span id="user-email"></span>
        <span class="badge">superadmin</span>
        <button class="logout" id="logout-btn" data-i18n="logout">Odhl\u00e1sit</button>
      </div>
    </div>

    <button class="btn btn-test-all" id="test-all-btn" data-i18n="testAll">Otestovat v\u0161e</button>

    <div class="card" id="card-supabase">
      <div class="card-title">\ud83d\uddc4\ufe0f Supabase <span class="key-status pending" id="status-supabase">?</span></div>
      <div class="key-row">
        <input type="password" class="key-input" id="key-supabase" placeholder="sb_sec... nebo eyJ...">
        <button class="btn btn-outline" id="show-supabase">\ud83d\udc41</button>
        <button class="btn" id="test-supabase" data-i18n="test">Test</button>
      </div>
      <details>
        <summary data-i18n="whereToFind">Kde kl\u00ed\u010d naj\u00edt?</summary>
        <div class="help-text">
          Supabase Dashboard \u2192 Settings \u2192 API \u2192 <code>service_role</code> key<br>
          URL: <code>https://supabase.com/dashboard</code>
        </div>
      </details>
    </div>

    <div class="card" id="card-resend">
      <div class="card-title">\ud83d\udce7 Resend <span class="key-status pending" id="status-resend">?</span></div>
      <div class="key-row">
        <input type="password" class="key-input" id="key-resend" placeholder="re_...">
        <button class="btn btn-outline" id="show-resend">\ud83d\udc41</button>
        <button class="btn" id="test-resend" data-i18n="test">Test</button>
      </div>
      <details>
        <summary data-i18n="whereToFind">Kde kl\u00ed\u010d naj\u00edt?</summary>
        <div class="help-text">
          resend.com \u2192 API Keys \u2192 Create API Key<br>
          \u26a0\ufe0f Dom\u00e9na <code>bass443.com</code> mus\u00ed b\u00fdt ov\u011b\u0159ena v DNS
        </div>
      </details>
    </div>

    <div class="card" id="card-fio">
      <div class="card-title">\ud83c\udfe6 Fio banka <span class="key-status pending" id="status-fio">?</span></div>
      <div class="key-row">
        <input type="password" class="key-input" id="key-fio" placeholder="token z Fio IB">
        <button class="btn btn-outline" id="show-fio">\ud83d\udc41</button>
        <button class="btn" id="test-fio" data-i18n="test">Test</button>
      </div>
      <details>
        <summary data-i18n="whereToFind">Kde kl\u00ed\u010d naj\u00edt?</summary>
        <div class="help-text">
          Fio Internetbanking \u2192 Nastaven\u00ed \u2192 API \u2192 Token pro \u010dten\u00ed<br>
          \u26a0\ufe0f Rate limit: 1 request / 30 s. Token m\u016f\u017ee expirovat!
        </div>
      </details>
    </div>

    <div class="card" id="card-internal">
      <div class="card-title">\ud83d\udd10 Internal Auth Token <span class="key-status pending" id="status-internal">?</span></div>
      <div class="key-row">
        <input type="password" class="key-input" id="key-internal" placeholder="vlastn\u00ed token">
        <button class="btn btn-outline" id="show-internal">\ud83d\udc41</button>
        <button class="btn" id="test-internal" data-i18n="test">Test</button>
      </div>
      <details>
        <summary data-i18n="whereToFind">Kde kl\u00ed\u010d naj\u00edt?</summary>
        <div class="help-text">
          Vlastn\u00ed vygenerovan\u00fd token (UUID/random 64+ char).<br>
          Ulo\u017een ve spr\u00e1vci hesel a v Cloudflare Worker Secrets.
        </div>
      </details>
    </div>

    <div id="terminal-container"></div>
  </main>

  <script src="/terminal.js" is:inline></script>
  <script>
    var ADMIN_API_URL = "https://admin-api.bass443.workers.dev";
    function getToken() { var t = localStorage.getItem("sb_token"); if (!t) { window.location.href = "/login"; return null; } return t; }

    var services = ["supabase","resend","fio","internal"];

    // Toggle password visibility
    services.forEach(function(svc) {
      document.getElementById("show-" + svc).addEventListener("click", function() {
        var inp = document.getElementById("key-" + svc);
        inp.type = inp.type === "password" ? "text" : "password";
      });
    });

    // Test single service
    async function testKey(svc) {
      var keyVal = document.getElementById("key-" + svc).value.trim();
      if (!keyVal) { window.term.error(svc + " \u2014 pr\u00e1zdn\u00fd kl\u00ed\u010d!"); return; }
      var statusEl = document.getElementById("status-" + svc);
      statusEl.className = "key-status pending";
      statusEl.textContent = "...";
      var btn = document.getElementById("test-" + svc);
      btn.disabled = true;
      window.term.info("Testuji " + svc + "...");
      try {
        var token = getToken();
        var res = await fetch(ADMIN_API_URL + "/superadmin/test-api-key", {
          method: "POST",
          headers: { "Authorization": "Bearer " + token, "Content-Type": "application/json" },
          body: JSON.stringify({ service: svc, key: keyVal })
        });
        var data = await res.json();
        if (data.status === "ok") {
          statusEl.className = "key-status ok";
          statusEl.textContent = "OK";
          window.term.ok(svc + " \u2014 " + data.detail);
        } else {
          statusEl.className = "key-status error";
          statusEl.textContent = "CHYBA";
          window.term.error(svc + " \u2014 " + data.detail);
        }
      } catch (e) {
        statusEl.className = "key-status error";
        statusEl.textContent = "CHYBA";
        window.term.error(svc + " \u2014 " + e.message);
      } finally {
        btn.disabled = false;
      }
    }

    services.forEach(function(svc) {
      document.getElementById("test-" + svc).addEventListener("click", function() { testKey(svc); });
    });

    // Test all
    document.getElementById("test-all-btn").addEventListener("click", async function() {
      var btn = document.getElementById("test-all-btn");
      btn.disabled = true;
      window.term.clear();
      window.term.banner("Test v\u0161ech API kl\u00ed\u010d\u016f");
      for (var i = 0; i < services.length; i++) {
        await testKey(services[i]);
      }
      window.term.separator();
      window.term.info("Hotovo.");
      btn.disabled = false;
    });

    // Init
    (function init() {
      var user = JSON.parse(localStorage.getItem("sb_user") || "{}");
      if (user.role !== "superadmin") { window.location.href = "/login"; return; }
      document.getElementById("user-email").textContent = user.email || "";
    })();
    document.getElementById("logout-btn").addEventListener("click", function() { localStorage.clear(); window.location.href = "/login"; });
  </script>
</body>
</html>